# Tests
/tests/tests/
/tests/results/
test-cookie.txt
test_db3.php

# Allow attendance import test fixtures (override *.dat / *.csv / *.sql ignores above)
!tests/fixtures/**/*.dat
!tests/fixtures/**/*.csv
!tests/fixtures/**/*.json
!tests/fixtures/**/*.sql

# Allow specific schema migration scripts under database/ (per file, supaya
# tidak accidentally expose data karyawan/jadwal yang juga di-stage di sini).
!database/add_early_leave_columns.sql
!database/backfill_sakit_presence_get_paid.sql

# User Guide
/user_guide/
user_guide_src/build/*
user_guide_src/cilexer/build/*
user_guide_src/cilexer/dist/*
user_guide_src/cilexer/pycilexer.egg-info/*

